# Allow-list .gitignore for $HOME-as-dotfiles repo.
# Default: ignore everything. Whitelist only the files we explicitly track.
# When adding a new tracked file: unignore its parent dirs first, then the file.

# ignore everything at root
/*

# whitelist tracked top-level dotfiles/dirs
!/.claude/
!/.config/
!/.git.scmbrc
!/.gitconfig
!/.gitignore
!/.gnupg/
!/.hushlogin
!/.ripgreprc
!/.ssh/
!/.tmux.conf
!/.zprofile
!/.zshrc
!/Brewfile
!/README.md

# .claude
/.claude/*
!/.claude/CLAUDE.md
!/.claude/mcp.json
!/.claude/mcp-library.json
!/.claude/scripts/
!/.claude/settings.json
/.claude/scripts/*
!/.claude/scripts/tmux-rename.sh

# .config
/.config/*
!/.config/bat/
!/.config/ghostty/
!/.config/git/
!/.config/nvim/
!/.config/starship.toml

/.config/bat/*
!/.config/bat/config

/.config/ghostty/*
!/.config/ghostty/config

/.config/git/*
!/.config/git/allowed_signers
!/.config/git/ignore

/.config/nvim/*
!/.config/nvim/lua/

/.config/nvim/lua/*
!/.config/nvim/lua/community.lua
!/.config/nvim/lua/lazy_setup.lua
!/.config/nvim/lua/plugins/
!/.config/nvim/lua/polish.lua

/.config/nvim/lua/plugins/*
!/.config/nvim/lua/plugins/astrocore.lua
!/.config/nvim/lua/plugins/astrolsp.lua
!/.config/nvim/lua/plugins/astroui.lua
!/.config/nvim/lua/plugins/user.lua

# .gnupg
/.gnupg/*
!/.gnupg/gpg-agent.conf

# .ssh
/.ssh/*
!/.ssh/config
